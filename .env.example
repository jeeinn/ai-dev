# 复制为 .env 后填入真实值（.env 请勿提交到 git）
# Systemd 可通过 EnvironmentFile 加载；也可在 shell 中 export 后启动 gateway。

# Gitea
GITEA_ADMIN_TOKEN=
GITEA_WEBHOOK_SECRET=

# LLM（按所用 Provider 填写）
DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Web UI / JWT（生产环境必须更换）
JWT_SECRET=change-me-in-production
ADMIN_PASSWORD=admin123

# 管理 API（可选；留空则 API 不校验 Bearer）
API_AUTH_TOKEN=

# OpenCode sidecar（可选 Path A）
# OPENCODE_SERVER_PASSWORD=
